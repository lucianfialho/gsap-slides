{
  "name": "gsap-slides",
  "version": "0.1.0",
  "description": "Create animated slide decks from Markdown using GSAP",
  "type": "module",
  "bin": {
    "gsap-slides": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup && vite build",
    "build:cli": "tsup",
    "build:viewer": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "gsap",
    "slides",
    "presentation",
    "markdown",
    "animation"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "gsap": "^3.12.5",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "optionalDependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
